APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://tu-dominio.com
APP_ENVIRONMENT=DEV

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nombre_base_de_datos
DB_USERNAME=usuario_db
DB_PASSWORD=contraseña_db

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=tls
MAIL_HOST=tu-mail-host.mail.protection.outlook.com
MAIL_ENCRYPTION=tls
MAIL_PORT=587
MAIL_USERNAME=tu-correo@tu-dominio.com
MAIL_PASSWORD=tu_contraseña_de_correo
MAIL_FROM_ADDRESS=tu-correo@tu-dominio.com
MAIL_FROM_NAME="Nombre de tu app"

# CORS - Orígenes permitidos (separados por coma). Usar * solo en desarrollo.
# Ejemplo producción: https://hieloyaventura.com,https://admin.hieloyaventura.com,https://agencias.hieloyaventura.com
CORS_ALLOWED_ORIGINS=*

# URLs internas de la aplicación
API_HYA=https://url-interna-api.tu-dominio.com
URL_HYA=https://url-interna.tu-dominio.com
AGENCIES_URL=https://agencias.tu-dominio.com

# JWT
JWT_SECRET=clave_secreta_jwt

# MercadoPago
MP_ACCESS_TOKEN_WEBHOOK=tu_access_token_webhook
MP_ACCESS_TOKEN_DEV=tu_access_token_dev
MP_PLATFORM_ID=tu_platform_id

# Emails de negocio
RESERVATION_MODIFICATION_EMAIL=email-reservas@tu-dominio.com
CONSULT_EMAIL_ADRESS=email-consultas@tu-dominio.com

# Alertas de seguridad: emails separados por coma que recibirán notificaciones de rate limiting y detección de bots
SECURITY_ALERT_EMAILS=sistemas@hieloyaventura.com,info@daptee.com.ar

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
